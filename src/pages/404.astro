---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { url } from '../lib/urls';
---

<BaseLayout
  title="Pagina niet gevonden — Iwan Stepanova"
  description="De pagina die je zoekt bestaat niet of is verplaatst."
>
  <section class="flex-1 flex items-center justify-center min-h-[60vh] bg-surface-alt dot-grid">
    <div class="max-w-xl mx-auto px-4 sm:px-6 text-center py-20 lg:py-28">
      <span
        class="font-display italic text-[8rem] lg:text-[10rem] leading-none text-accent/30 select-none block"
      >
        404
      </span>
      <h1 class="font-sans font-semibold text-3xl lg:text-4xl text-primary mt-2 tracking-tight">
        Pagina niet gevonden
      </h1>
      <p class="font-sans text-neutral-500 mt-4 leading-relaxed">
        De pagina die je zoekt bestaat niet of is verplaatst. Ga terug naar de homepage of bekijk
        het dienstenoverzicht.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <Button href={url('/')} variant="primary" size="lg"> Terug naar home </Button>
        <Button href={url('/services/')} variant="outline" size="lg"> Bekijk diensten </Button>
      </div>
    </div>
  </section>
</BaseLayout>

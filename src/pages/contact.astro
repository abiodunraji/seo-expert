---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact"
  description="Neem contact op met Iwan Stepanova voor een vrijblijvend gesprek over jouw SEO-groei."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 lg:py-28 bg-surface-alt dot-grid">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[600px] bg-accent/5 rounded-full blur-[120px]"
    >
    </div>

    <!-- Constellation (desktop only) -->
    <svg
      class="hidden lg:block absolute top-10 right-14 pointer-events-none select-none"
      width="260"
      height="200"
      viewBox="0 0 260 200"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <line
        x1="130"
        y1="100"
        x2="42"
        y2="35"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0s"></line>
      <line
        x1="130"
        y1="100"
        x2="220"
        y2="48"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.1s"></line>
      <line
        x1="130"
        y1="100"
        x2="238"
        y2="148"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.2s"></line>
      <line
        x1="130"
        y1="100"
        x2="88"
        y2="175"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.3s"></line>
      <line
        x1="42"
        y1="35"
        x2="220"
        y2="48"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.18"
        class="constellation-line"
        style="animation-delay: 0.4s"></line>
      <line
        x1="88"
        y1="175"
        x2="238"
        y2="148"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.18"
        class="constellation-line"
        style="animation-delay: 0.45s"></line>
      <line
        x1="42"
        y1="35"
        x2="15"
        y2="12"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.15"
        class="constellation-line"
        style="animation-delay: 0.55s"></line>
      <line
        x1="220"
        y1="48"
        x2="252"
        y2="18"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.15"
        class="constellation-line"
        style="animation-delay: 0.6s"></line>
      <circle
        cx="130"
        cy="100"
        r="4.5"
        fill="#C8A882"
        opacity="0.65"
        class="constellation-node"
        style="--node-opacity: 0.65; animation-delay: 0.15s"></circle>
      <circle
        cx="42"
        cy="35"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.5s"></circle>
      <circle
        cx="220"
        cy="48"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.55s"></circle>
      <circle
        cx="238"
        cy="148"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.60; animation-delay: 0.6s"></circle>
      <circle
        cx="88"
        cy="175"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.65s"></circle>
      <circle
        cx="15"
        cy="12"
        r="1.6"
        fill="#C8A882"
        opacity="0.30"
        class="constellation-node"
        style="--node-opacity: 0.30; animation-delay: 0.75s"></circle>
      <circle
        cx="252"
        cy="18"
        r="1.6"
        fill="#C8A882"
        opacity="0.30"
        class="constellation-node"
        style="--node-opacity: 0.30; animation-delay: 0.8s"></circle>
    </svg>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Content -->
        <div>
          <span class="section-label">Contact</span>
          <h1
            class="font-semibold text-4xl lg:text-5xl xl:text-6xl mt-5 tracking-tight leading-[1.1]"
          >
            <span class="font-display italic text-primary block">Laten we</span>
            <span class="font-sans text-primary-light block">praten</span>
          </h1>
          <p class="font-sans text-lg text-neutral-500 mt-6 leading-relaxed">
            Klaar om jouw online zichtbaarheid naar een hoger niveau te tillen? Plan een
            vrijblijvend gesprek en ontdek hoe ik jouw bedrijf kan helpen.
          </p>

          <!-- Direct Contact Options -->
          <div class="mt-12 space-y-5">
            <div class="group flex items-center gap-4">
              <div
                class="w-12 h-12 bg-surface rounded-lg border border-neutral-300 flex items-center justify-center transition-all duration-300 group-hover:border-accent/50 group-hover:bg-accent/5 group-hover:shadow-soft"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-primary-light"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs text-neutral-500 uppercase tracking-[0.15em]">Email</p>
                <p class="font-sans text-primary">hallo@iwanstepanova.com</p>
              </div>
            </div>

            <div class="group flex items-center gap-4">
              <div
                class="w-12 h-12 bg-surface rounded-lg border border-neutral-300 flex items-center justify-center transition-all duration-300 group-hover:border-accent/50 group-hover:bg-accent/5 group-hover:shadow-soft"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-primary-light"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs text-neutral-500 uppercase tracking-[0.15em]">
                  Telefoon
                </p>
                <a
                  href="tel:+31623872013"
                  class="font-sans text-primary hover:text-primary-light transition-colors duration-300"
                >
                  +31 6 238 7 2013
                </a>
              </div>
            </div>

            <div class="group flex items-center gap-4">
              <div
                class="w-12 h-12 bg-surface rounded-lg border border-neutral-300 flex items-center justify-center transition-all duration-300 group-hover:border-accent/50 group-hover:bg-accent/5 group-hover:shadow-soft"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 text-primary-light"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"
                  ></path>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs text-neutral-500 uppercase tracking-[0.15em]">
                  LinkedIn
                </p>
                <a
                  href="https://www.linkedin.com/in/iwan-stepanova-seo/"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-primary hover:text-primary-light transition-colors duration-300"
                >
                  iwan-stepanova-seo
                </a>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="bg-surface rounded-xl border border-neutral-300 p-8 shadow-soft">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

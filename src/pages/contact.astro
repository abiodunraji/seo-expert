---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout 
  title="Contact"
  description="Neem contact op met Iwan Stepanova voor een vrijblijvend gesprek over jouw SEO-groei."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <!-- Content -->
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-cyan/70">
            Contact
          </span>
          <h1 class="font-space font-bold text-4xl lg:text-5xl xl:text-6xl text-offwhite mt-4 tracking-tight">
            Laten we <span class="text-cyan">praten</span>
          </h1>
          <p class="font-inter text-lg text-slategray mt-6 leading-relaxed">
            Klaar om jouw online zichtbaarheid naar een hoger niveau te tillen?
            Plan een vrijblijvend gesprek en ontdek hoe ik jouw bedrijf kan helpen.
          </p>
          
          <!-- Direct Contact Options -->
          <div class="mt-12 space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-surface rounded-xl border border-white/5 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs text-slategray uppercase tracking-[0.15em]">
                  Email
                </p>
                <p class="font-inter text-offwhite">
                  hallo@iwanstepanova.com
                </p>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-surface rounded-xl border border-white/5 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs text-slategray uppercase tracking-[0.15em]">
                  Telefoon
                </p>
                <a href="tel:+31623872013" class="font-inter text-cyan hover:text-offwhite transition-colors duration-300">
                  +31 6 238 7 2013
                </a>
              </div>
            </div>
            
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-surface rounded-xl border border-white/5 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z" />
                  <circle cx="4" cy="4" r="2" />
                </svg>
              </div>
              <div>
                <p class="font-mono text-xs text-slategray uppercase tracking-[0.15em]">
                  LinkedIn
                </p>
                <a href="https://www.linkedin.com/in/iwan-stepanova-seo/" target="_blank" rel="noopener noreferrer" class="font-inter text-cyan hover:text-offwhite transition-colors duration-300">
                  iwan-stepanova-seo
                </a>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Contact Form -->
        <div class="bg-surface rounded-2xl border border-white/5 p-8 shadow-soft">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { url } from '../../lib/urls';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await service.render();

const heroImage = url(service.data.image || `/images/services/${service.slug}.svg`);

// Distinct stock photos per service per section (Unsplash, royalty-free)
const servicePhotos: Record<string, { overview: string; importance: string; approach: string; results: string }> = {
  strategie: {
    overview: 'https://images.unsplash.com/photo-1552664730-d307ca884978?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80',
  },
  analyse: {
    overview: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1504868584819-f8e8b4b6d7e3?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80',
  },
  content: {
    overview: 'https://images.unsplash.com/photo-1455390582262-044cdead277a?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1432888622747-4eb9a8efeb07?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1488190211105-8b0e65b80b4e?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1434030216411-0b793f4b4173?w=800&q=80',
  },
  'technical-seo': {
    overview: 'https://images.unsplash.com/photo-1461749280684-dccba630e2f6?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1504639725590-34d0984388bd?w=800&q=80',
  },
  'offpage-seo': {
    overview: 'https://images.unsplash.com/photo-1521791136064-7986c2920216?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1557804506-669a67965ba0?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1553877522-43269d4ea984?w=800&q=80',
  },
  'local-seo': {
    overview: 'https://images.unsplash.com/photo-1524661135-423995f22d0b?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1526304640581-d334cdbbf45e?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1556761175-4b46a572b786?w=800&q=80',
  },
  geo: {
    overview: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&q=80',
    importance: 'https://images.unsplash.com/photo-1620712943543-bcc4688e7485?w=800&q=80',
    approach: 'https://images.unsplash.com/photo-1677442136019-21780ecad995?w=800&q=80',
    results: 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?w=800&q=80',
  },
};

const photos = servicePhotos[service.slug] || servicePhotos.strategie;

const sectionKeys = ['overview', 'importance', 'approach', 'results'] as const;

const sections = [
  {
    title: 'Wat houdt het in?',
    description: service.data.description,
    image: photos.overview,
    imageAlt: `${service.data.title} overzicht`,
    reverse: false,
  },
  {
    title: 'Waarom dit belangrijk is',
    description: 'In een competitieve digitale markt is het essentieel om voorop te lopen. Deze dienst helpt je om onderscheidend vermogen te creëren en duurzame groei te realiseren.',
    image: photos.importance,
    imageAlt: `${service.data.title} belang`,
    reverse: true,
  },
  {
    title: 'Mijn aanpak',
    description: 'Ik werk met een bewezen methodiek die resultaten levert. Van intake tot implementatie — elke stap is doordacht en meetbaar.',
    image: photos.approach,
    imageAlt: `${service.data.title} aanpak`,
    reverse: false,
  },
  {
    title: 'Wat je kunt verwachten',
    description: 'Transparante communicatie, meetbare resultaten en een partnership dat jouw bedrijf naar het volgende niveau tilt.',
    image: photos.results,
    imageAlt: `${service.data.title} resultaten`,
    reverse: true,
  },
];
---

<BaseLayout 
  title={service.data.title}
  description={service.data.description}
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-28 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div>
          <span class="font-mono text-xs uppercase tracking-[0.15em] text-primary-light">
            Service
          </span>
          <h1 class="font-sans font-semibold text-4xl lg:text-5xl xl:text-6xl text-primary mt-4 tracking-tight">
            {service.data.title}
          </h1>
          <p class="font-sans text-lg text-neutral-500 mt-6 leading-relaxed">
            {service.data.description}
          </p>
          
          {service.data.featured && (
            <div class="inline-block bg-accent/10 text-primary px-4 py-1.5 mt-6 font-mono text-xs uppercase tracking-wider rounded-lg border border-accent/30">
              Aanbevolen
            </div>
          )}
        </div>
        
        <!-- Hero Image -->
        <div class="hidden lg:block">
          <div class="relative">
            <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-3xl"></div>
            <div class="relative bg-surface rounded-2xl border border-neutral-300 overflow-hidden shadow-soft">
              <img 
                src={heroImage} 
                alt={service.data.title}
                class="w-full h-auto"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Alternating Content Sections -->
  {sections.map((section, index) => (
    <section class:list={[
      'border-t border-neutral-300',
      section.reverse && 'bg-surface-alt'
    ]}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Text -->
          <div class:list={[section.reverse && 'lg:order-2']}>
            <span class="font-mono text-xs text-primary/60 uppercase tracking-[0.15em]">
              0{index + 1}
            </span>
            <h2 class="font-sans font-semibold text-2xl lg:text-3xl text-primary mt-2 mb-6 tracking-tight">
              {section.title}
            </h2>
            <p class="font-sans text-neutral-500 leading-relaxed">
              {section.description}
            </p>
          </div>
          
          <!-- Image -->
          <div class:list={[section.reverse && 'lg:order-1']}>
            <div class="relative">
              <div class="relative bg-surface rounded-xl border border-neutral-300 overflow-hidden aspect-[4/3]">
                <img 
                  src={section.image} 
                  alt={section.imageAlt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  width="800"
                  height="600"
                />
              </div>
            </div>
          </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- MDX Content Section -->
  <section class="border-t border-neutral-300 bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-3xl">
        <h2 class="font-sans font-semibold text-2xl lg:text-3xl text-primary mb-8 tracking-tight">
          Details
        </h2>
        <div class="prose prose-lg max-w-none">
          <article class="font-sans text-primary">
            <Content />
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="border-t border-neutral-300 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="relative bg-surface rounded-2xl border border-neutral-300 p-10 lg:p-16 text-center overflow-hidden shadow-soft">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-accent/10 rounded-full blur-[100px]"></div>
        <div class="relative">
          <h2 class="font-sans font-semibold text-3xl lg:text-4xl text-primary tracking-tight">
            Geïnteresseerd in <span class="text-primary-light">{service.data.title}</span>?
          </h2>
          <p class="font-sans text-neutral-500 mt-4 max-w-xl mx-auto leading-relaxed">
            Laten we bespreken hoe ik jouw bedrijf kan helpen met deze dienst.
            Samen werken we aan jouw online groei.
          </p>
          <div class="mt-8">
            <Button href={url('/contact/')} variant="primary" size="lg">
              Plan een gesprek
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
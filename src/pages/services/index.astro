---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import { getCollection } from 'astro:content';
import { url } from '../../lib/urls';

const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Services"
  description="Alle SEO-diensten van Iwan Stepanova: Strategie, Analyse, Content, Technical SEO, Off-page SEO, Local SEO en GEO."
>
  <!-- Hero Section -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-cyan/70">
          Diensten
        </span>
        <h1 class="font-space font-bold text-4xl lg:text-5xl xl:text-6xl text-offwhite mt-4 tracking-tight">
          Complete <span class="text-cyan">SEO-expertise</span>
        </h1>
        <p class="font-inter text-slategray mt-4 max-w-2xl mx-auto leading-relaxed">
          Van technische optimalisatie tot AI-gestuurde zoekmachine strategie.
          Ik bied alle diensten om jouw merk online te laten domineren.
        </p>
      </div>

      <BentoGrid columns={3} gap="md" centerLastRow>
        {sortedServices.map((service) => (
          <ServiceCard 
            title={service.data.title}
            description={service.data.description}
            icon={service.data.icon}
            href={url(`/services/${service.slug}`)}
            featured={service.data.featured}
          />
        ))}
      </BentoGrid>
    </div>
  </section>
</BaseLayout>
---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Over Iwan Stepanova"
  description="Leer Iwan Stepanova kennen — SEO expert met een strategische blik op zoekmachine optimalisatie en content architectuur."
>
  <!-- Hero Section -->
  <section class="border-b-2 border-cyan">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div>
          <span class="font-mono text-sm text-cyan uppercase tracking-wider">
            Over mij
          </span>
          <h1 class="font-space font-bold text-4xl lg:text-5xl xl:text-6xl text-offwhite mt-4">
            Iwan <span class="text-cyan">Stepanova</span>
          </h1>
          <p class="font-inter text-lg text-slategray mt-6">
            Strategisch SEO architect met een passie voor groei. 
            Ik help ondernemingen om te domineren in zoekmachines door slimme strategieën 
            en toekomstbestendige technologieën.
          </p>
        </div>
        
        <!-- Image Placeholder -->
        <div class="relative">
          <div class="absolute -inset-4 border-2 border-cyan/30"></div>
          <div class="absolute -inset-2 border border-cyan/60"></div>
          <div class="relative bg-surface aspect-square flex items-center justify-center brutal-border">
            <div class="text-center">
              <div class="w-32 h-32 mx-auto mb-6 rounded-full bg-cyan/20 flex items-center justify-center">
                <span class="font-space font-bold text-5xl text-cyan">IS</span>
              </div>
              <p class="font-mono text-sm text-slategray">
                [Foto komt nog]
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Background Section -->
  <section class="border-b-2 border-cyan">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="max-w-2xl">
        <h2 class="font-space font-bold text-2xl lg:text-3xl text-offwhite mb-6">
          Mijn achtergrond
        </h2>
        <div class="font-inter text-slategray space-y-4">
          <p>
            Met jaren ervaring in SEO heb ik gezien hoe de industrie is veranderd. 
            Van traditionele trefwoorden tot AI-gestuurde zoekervaringen — 
            ik help merken om vooruit te blijven.
          </p>
          <p>
            Mijn aanpak is strategisch: niet zomaar traffic, maar de juiste bezoekers 
            die converteren. Ik denk mee over de hele klantreis.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="font-mono text-sm text-cyan uppercase tracking-wider">
          Waar ik voor sta
        </span>
        <h2 class="font-space font-bold text-3xl lg:text-4xl text-offwhite mt-4">
          Mijn <span class="text-cyan">waarden</span>
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-surface brutal-border p-6">
          <h3 class="font-space font-bold text-xl text-offwhite mb-3">
            Strategie eerst
          </h3>
          <p class="font-inter text-slategray text-sm">
            Tactiek zonder strategie is als schieten in het donker. 
            Ik zorg voor een doordachte aanpak.
          </p>
        </div>
        
        <div class="bg-surface brutal-border p-6">
          <h3 class="font-space font-bold text-xl text-offwhite mb-3">
            Meetbare resultaten
          </h3>
          <p class="font-inter text-slategray text-sm">
            Wat niet gemeten wordt, kan niet verbeterd worden. 
            Ik rapporteer over concrete groei.
          </p>
        </div>
        
        <div class="bg-surface brutal-border p-6">
          <h3 class="font-space font-bold text-xl text-offwhite mb-3">
            Toekomstbestendig
          </h3>
          <p class="font-inter text-slategray text-sm">
            SEO verandert constant. 
            Ik zorg dat jouw merk klaar is voor wat komen gaat.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
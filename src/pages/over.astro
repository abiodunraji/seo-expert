---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { url } from '../lib/urls';
---

<BaseLayout
  title="Over Iwan Stepanova"
  description="Leer Iwan Stepanova kennen — SEO expert met een strategische blik op zoekmachine optimalisatie en content architectuur."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 lg:py-28 bg-surface-alt dot-grid">
    <div
      class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[700px] bg-accent/5 rounded-full blur-[120px]"
    >
    </div>

    <!-- Constellation (desktop only) -->
    <svg
      class="hidden lg:block absolute top-10 right-14 pointer-events-none select-none"
      width="280"
      height="220"
      viewBox="0 0 280 220"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <line
        x1="140"
        y1="110"
        x2="48"
        y2="38"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0s"></line>
      <line
        x1="140"
        y1="110"
        x2="235"
        y2="55"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.1s"></line>
      <line
        x1="140"
        y1="110"
        x2="255"
        y2="158"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.2s"></line>
      <line
        x1="140"
        y1="110"
        x2="95"
        y2="188"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.3s"></line>
      <line
        x1="140"
        y1="110"
        x2="32"
        y2="140"
        stroke="#C8A882"
        stroke-width="0.75"
        opacity="0.45"
        class="constellation-line"
        style="animation-delay: 0.4s"></line>
      <line
        x1="48"
        y1="38"
        x2="235"
        y2="55"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.18"
        class="constellation-line"
        style="animation-delay: 0.5s"></line>
      <line
        x1="32"
        y1="140"
        x2="95"
        y2="188"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.18"
        class="constellation-line"
        style="animation-delay: 0.55s"></line>
      <line
        x1="48"
        y1="38"
        x2="18"
        y2="12"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.15"
        class="constellation-line"
        style="animation-delay: 0.65s"></line>
      <line
        x1="235"
        y1="55"
        x2="270"
        y2="22"
        stroke="#C8A882"
        stroke-width="0.5"
        opacity="0.15"
        class="constellation-line"
        style="animation-delay: 0.7s"></line>
      <circle
        cx="140"
        cy="110"
        r="4.5"
        fill="#C8A882"
        opacity="0.65"
        class="constellation-node"
        style="--node-opacity: 0.65; animation-delay: 0.15s"></circle>
      <circle
        cx="48"
        cy="38"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.5s"></circle>
      <circle
        cx="235"
        cy="55"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.55s"></circle>
      <circle
        cx="255"
        cy="158"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.6s"></circle>
      <circle
        cx="95"
        cy="188"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.65s"></circle>
      <circle
        cx="32"
        cy="140"
        r="2.8"
        fill="#C8A882"
        opacity="0.50"
        class="constellation-node"
        style="--node-opacity: 0.50; animation-delay: 0.7s"></circle>
      <circle
        cx="18"
        cy="12"
        r="1.6"
        fill="#C8A882"
        opacity="0.30"
        class="constellation-node"
        style="--node-opacity: 0.30; animation-delay: 0.8s"></circle>
      <circle
        cx="270"
        cy="22"
        r="1.6"
        fill="#C8A882"
        opacity="0.30"
        class="constellation-node"
        style="--node-opacity: 0.30; animation-delay: 0.85s"></circle>
    </svg>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content -->
        <div>
          <span class="section-label">Over mij</span>
          <h1
            class="font-semibold text-4xl lg:text-5xl xl:text-6xl mt-5 tracking-tight leading-[1.1]"
          >
            <span class="font-display italic text-primary block">Iwan</span>
            <span class="font-sans text-primary-light block">Stepanova</span>
          </h1>
          <p class="font-sans text-lg text-neutral-500 mt-6 leading-relaxed">
            Strategisch SEO architect met een passie voor groei. Ik help ondernemingen om te
            domineren in zoekmachines door slimme strategieën en toekomstbestendige technologieën.
          </p>
        </div>

        <!-- Image -->
        <div class="relative">
          <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-3xl"></div>
          <div
            class="relative bg-surface rounded-2xl border border-neutral-300 overflow-hidden shadow-soft"
          >
            <img
              src={url('/images/iwan.png')}
              alt="Iwan Stepanova"
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Background Section -->
  <section class="signal-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-2xl">
        <span class="section-label">Mijn achtergrond</span>
        <h2 class="text-2xl lg:text-3xl mt-5 mb-6 tracking-tight">
          <span class="font-display italic text-primary">Ervaring</span>
          <span class="font-sans font-semibold text-primary-light"> die het verschil maakt</span>
        </h2>
        <div class="font-sans text-neutral-500 space-y-4 leading-relaxed">
          <p>
            Met jaren ervaring in SEO heb ik gezien hoe de industrie is veranderd. Van traditionele
            trefwoorden tot AI-gestuurde zoekervaringen — ik help merken om vooruit te blijven.
          </p>
          <p>
            Mijn aanpak is strategisch: niet zomaar traffic, maar de juiste bezoekers die
            converteren. Ik denk mee over de hele klantreis.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="signal-section bg-surface-alt dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-16">
        <span class="section-label">Waar ik voor sta</span>
        <h2 class="text-3xl lg:text-4xl mt-5 tracking-tight">
          <span class="font-display italic text-primary">Mijn</span>
          <span class="font-sans font-semibold text-primary-light"> waarden</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card card-signal">
          <h3 class="font-sans font-semibold text-xl text-primary mb-3">Strategie eerst</h3>
          <p class="font-sans text-neutral-500 text-sm leading-relaxed">
            Tactiek zonder strategie is als schieten in het donker. Ik zorg voor een doordachte
            aanpak.
          </p>
        </div>

        <div class="card card-signal">
          <h3 class="font-sans font-semibold text-xl text-primary mb-3">Meetbare resultaten</h3>
          <p class="font-sans text-neutral-500 text-sm leading-relaxed">
            Wat niet gemeten wordt, kan niet verbeterd worden. Ik rapporteer over concrete groei.
          </p>
        </div>

        <div class="card card-signal">
          <h3 class="font-sans font-semibold text-xl text-primary mb-3">Toekomstbestendig</h3>
          <p class="font-sans text-neutral-500 text-sm leading-relaxed">
            SEO verandert constant. Ik zorg dat jouw merk klaar is voor wat komen gaat.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Expertise Section -->
  <section class="signal-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-16">
        <span class="section-label">Expertise</span>
        <h2 class="text-3xl lg:text-4xl mt-5 tracking-tight">
          <span class="font-display italic text-primary">Wat ik</span>
          <span class="font-sans font-semibold text-primary-light"> beheers</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6" id="expertise-grid">
        <div class="card text-center expertise-card">
          <span class="font-display italic text-5xl text-primary block mb-1" data-expertise="95"
            >95</span
          >
          <span class="font-mono text-xs text-accent uppercase tracking-widest">%</span>
          <span class="font-sans text-sm text-neutral-500 block mt-3">Technical SEO</span>
          <div class="expertise-bar mt-4"><div class="expertise-fill" data-width="95"></div></div>
        </div>
        <div class="card text-center expertise-card">
          <span class="font-display italic text-5xl text-primary block mb-1" data-expertise="90"
            >90</span
          >
          <span class="font-mono text-xs text-accent uppercase tracking-widest">%</span>
          <span class="font-sans text-sm text-neutral-500 block mt-3">Content Strategie</span>
          <div class="expertise-bar mt-4"><div class="expertise-fill" data-width="90"></div></div>
        </div>
        <div class="card text-center expertise-card">
          <span class="font-display italic text-5xl text-primary block mb-1" data-expertise="85"
            >85</span
          >
          <span class="font-mono text-xs text-accent uppercase tracking-widest">%</span>
          <span class="font-sans text-sm text-neutral-500 block mt-3">Link Building</span>
          <div class="expertise-bar mt-4"><div class="expertise-fill" data-width="85"></div></div>
        </div>
        <div class="card text-center expertise-card">
          <span class="font-display italic text-5xl text-primary block mb-1" data-expertise="92"
            >92</span
          >
          <span class="font-mono text-xs text-accent uppercase tracking-widest">%</span>
          <span class="font-sans text-sm text-neutral-500 block mt-3">GEO / AI Search</span>
          <div class="expertise-bar mt-4"><div class="expertise-fill" data-width="92"></div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Approach / Werkwijze Section -->
  <section class="signal-section bg-surface-alt dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-16">
        <span class="section-label">Werkwijze</span>
        <h2 class="text-3xl lg:text-4xl mt-5 tracking-tight">
          <span class="font-display italic text-primary">Hoe ik</span>
          <span class="font-sans font-semibold text-primary-light"> werk</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 lg:gap-10">
        <div class="relative">
          <span
            class="font-display italic text-8xl text-accent/20 leading-none block mb-3 select-none"
            >01</span
          >
          <h3 class="font-sans font-semibold text-lg text-primary mb-2">Intake</h3>
          <p class="font-sans text-sm text-neutral-500 leading-relaxed">
            We starten met een vrijblijvend gesprek om jouw doelen en uitdagingen te begrijpen.
          </p>
          <div
            class="hidden md:block absolute top-10 right-0 w-px h-16 bg-gradient-to-b from-transparent via-neutral-300 to-transparent"
          >
          </div>
        </div>
        <div class="relative">
          <span
            class="font-display italic text-8xl text-accent/20 leading-none block mb-3 select-none"
            >02</span
          >
          <h3 class="font-sans font-semibold text-lg text-primary mb-2">Analyse</h3>
          <p class="font-sans text-sm text-neutral-500 leading-relaxed">
            Ik onderzoek je huidige situatie, concurrentie en groeikansen in detail.
          </p>
          <div
            class="hidden md:block absolute top-10 right-0 w-px h-16 bg-gradient-to-b from-transparent via-neutral-300 to-transparent"
          >
          </div>
        </div>
        <div class="relative">
          <span
            class="font-display italic text-8xl text-accent/20 leading-none block mb-3 select-none"
            >03</span
          >
          <h3 class="font-sans font-semibold text-lg text-primary mb-2">Strategie</h3>
          <p class="font-sans text-sm text-neutral-500 leading-relaxed">
            Op basis van de analyse ontwikkel ik een op maat gemaakte strategie.
          </p>
          <div
            class="hidden md:block absolute top-10 right-0 w-px h-16 bg-gradient-to-b from-transparent via-neutral-300 to-transparent"
          >
          </div>
        </div>
        <div>
          <span
            class="font-display italic text-8xl text-accent/20 leading-none block mb-3 select-none"
            >04</span
          >
          <h3 class="font-sans font-semibold text-lg text-primary mb-2">Uitvoering</h3>
          <p class="font-sans text-sm text-neutral-500 leading-relaxed">
            We implementeren de strategie en monitoren continu de resultaten.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Section -->
  <section class="signal-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-16">
        <span class="section-label">Tools & Technologie</span>
        <h2 class="text-3xl lg:text-4xl mt-5 tracking-tight">
          <span class="font-display italic text-primary">Mijn</span>
          <span class="font-sans font-semibold text-primary-light"> toolkit</span>
        </h2>
      </div>

      <div class="flex flex-wrap justify-center gap-3">
        {
          [
            'Google Search Console',
            'Google Analytics',
            'Ahrefs',
            'Screaming Frog',
            'SEMrush',
            'Google Tag Manager',
            'Schema.org',
            'PageSpeed Insights',
          ].map((tool) => (
            <span class="group bg-surface-alt border border-neutral-300 px-5 py-2.5 rounded-lg font-sans text-sm text-neutral-500 hover:text-primary hover:border-accent/40 hover:bg-accent/5 transition-all duration-300 cursor-default">
              {tool}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="signal-section bg-surface-alt dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div
        class="relative bg-surface rounded-2xl border border-neutral-300 p-10 lg:p-16 text-center overflow-hidden shadow-soft"
      >
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-accent/10 rounded-full blur-[100px]"
        >
        </div>

        <!-- Constellation motif -->
        <svg
          class="absolute bottom-0 right-0 pointer-events-none select-none opacity-60"
          width="200"
          height="170"
          viewBox="0 0 200 170"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <line
            x1="160"
            y1="130"
            x2="80"
            y2="80"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0s"></line>
          <line
            x1="160"
            y1="130"
            x2="190"
            y2="65"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0.1s"></line>
          <line
            x1="80"
            y1="80"
            x2="30"
            y2="110"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0.2s"></line>
          <line
            x1="80"
            y1="80"
            x2="110"
            y2="25"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0.3s"></line>
          <line
            x1="110"
            y1="25"
            x2="190"
            y2="65"
            stroke="#C8A882"
            stroke-width="0.5"
            opacity="0.2"
            class="constellation-line"
            style="animation-delay: 0.4s"></line>
          <line
            x1="30"
            y1="110"
            x2="160"
            y2="130"
            stroke="#C8A882"
            stroke-width="0.5"
            opacity="0.15"
            class="constellation-line"
            style="animation-delay: 0.45s"></line>
          <circle
            cx="80"
            cy="80"
            r="3.5"
            fill="#C8A882"
            opacity="0.6"
            class="constellation-node"
            style="--node-opacity: 0.6;  animation-delay: 0.1s"></circle>
          <circle
            cx="160"
            cy="130"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.45s"></circle>
          <circle
            cx="30"
            cy="110"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.5s"></circle>
          <circle
            cx="190"
            cy="65"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.55s"></circle>
          <circle
            cx="110"
            cy="25"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.6s"></circle>
        </svg>

        <div class="relative">
          <h2 class="text-3xl lg:text-4xl tracking-tight">
            <span class="font-display italic text-primary">Klaar om te</span>
            <span class="font-sans font-semibold text-primary-light"> groeien</span>?
          </h2>
          <p class="font-sans text-neutral-500 mt-4 max-w-xl mx-auto leading-relaxed">
            Laten we samenwerken aan jouw online succes. Neem contact op voor een vrijblijvend
            gesprek.
          </p>
          <div class="mt-8">
            <Button href={url('/contact/')} variant="primary" size="lg"> Neem contact op </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initExpertiseBars } from '@/lib/animations';
  initExpertiseBars();
</script>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BentoGrid from '../components/BentoGrid.astro';
import Button from '../components/Button.astro';
import { getCollection } from 'astro:content';
import { url } from '../lib/urls';

// Get services from content collection
const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);

// Client logos
const clientLogos = [
  { name: 'Client 1', src: url('/images/clients/logo1.png') },
  { name: 'Client 2', src: url('/images/clients/logo2.png') },
  { name: 'Client 3', src: url('/images/clients/logo3.png') },
  { name: 'Client 4', src: url('/images/clients/logo4.png') },
];

// Stats
const stats = [
  { value: '150+', label: 'Projecten voltooid' },
  { value: '95%', label: 'Klanttevredenheid' },
  { value: '3x', label: 'Gemiddelde groei' },
  { value: '8+', label: 'Jaar ervaring' },
];
---

<BaseLayout title="Iwan Stepanova — SEO Expert">
  <!-- Hero Section -->
  <Hero
    title="De Strategische Architect voor Zoekmachine Dominantie"
    subtitle="Technical SEO, Content Architectuur & GEO voor de merken van morgen. Ik help ondernemingen groeien door strategische zoekmachine zichtbaarheid."
    ctaText="Start je Project"
    ctaHref={url('/contact/')}
  />

  <!-- Stats Section -->
  <section class="signal-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-12">
        <span class="section-label">Resultaten</span>
        <h2 class="text-2xl lg:text-3xl mt-4 tracking-tight">
          <span class="font-display italic text-primary">Cijfers</span>
          <span class="font-sans font-semibold text-primary-light"> die spreken</span>
        </h2>
      </div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
        <div class="text-center">
          <div class="stat-radar inline-flex items-baseline justify-center">
            <span
              class="font-sans font-bold text-5xl lg:text-6xl text-primary stat-value"
              data-target="150">0</span
            >
            <span class="font-sans font-bold text-5xl lg:text-6xl text-primary">+</span>
          </div>
          <span class="font-sans text-sm text-neutral-500 mt-2 block">Projecten voltooid</span>
        </div>
        <div class="text-center">
          <div class="stat-radar inline-flex items-baseline justify-center">
            <span
              class="font-sans font-bold text-5xl lg:text-6xl text-primary stat-value"
              data-target="95">0</span
            >
            <span class="font-sans font-bold text-5xl lg:text-6xl text-primary">%</span>
          </div>
          <span class="font-sans text-sm text-neutral-500 mt-2 block">Klanttevredenheid</span>
        </div>
        <div class="text-center">
          <div class="stat-radar inline-flex items-baseline justify-center">
            <span
              class="font-sans font-bold text-5xl lg:text-6xl text-primary stat-value"
              data-target="3">0</span
            >
            <span class="font-sans font-bold text-5xl lg:text-6xl text-primary">x</span>
          </div>
          <span class="font-sans text-sm text-neutral-500 mt-2 block">Gemiddelde groei</span>
        </div>
        <div class="text-center">
          <div class="stat-radar inline-flex items-baseline justify-center">
            <span
              class="font-sans font-bold text-5xl lg:text-6xl text-primary stat-value"
              data-target="8">0</span
            >
            <span class="font-sans font-bold text-5xl lg:text-6xl text-primary">+</span>
          </div>
          <span class="font-sans text-sm text-neutral-500 mt-2 block">Jaar ervaring</span>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initStatCounters } from '@/lib/animations';
    initStatCounters();
  </script>

  <!-- Services Section -->
  <section class="signal-section bg-surface-alt dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="text-center mb-16">
        <span class="section-label">Diensten</span>
        <h2 class="text-3xl lg:text-4xl xl:text-5xl mt-4 tracking-tight">
          <span class="font-display italic text-primary">Jouw groei,</span>
          <span class="font-sans font-semibold text-primary-light"> mijn expertise</span>
        </h2>
        <p class="font-sans text-neutral-500 mt-4 max-w-2xl mx-auto leading-relaxed">
          Complete SEO-oplossingen van strategie tot uitvoering. Kies de dienst die bij jouw
          uitdaging past.
        </p>
      </div>

      <BentoGrid columns={3} gap="md">
        {
          sortedServices.map((service) => (
            <div class:list={[service.data.featured && 'lg:col-span-3']}>
              <ServiceCard
                title={service.data.title}
                description={service.data.description}
                icon={service.data.icon}
                href={url(`/services/${service.slug}`)}
                featured={service.data.featured}
              />
            </div>
          ))
        }
      </BentoGrid>
    </div>
  </section>

  <!-- Client Logo Wall -->
  <section class="signal-section bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="text-center mb-10">
        <span class="section-label">Vertrouwd door</span>
        <h2 class="font-sans font-semibold text-xl lg:text-2xl text-primary mt-3 tracking-tight">
          Ondernemingen die groeien
        </h2>
      </div>

      <!-- Logo Marquee -->
      <div class="relative overflow-hidden">
        <div
          class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-surface to-transparent z-10"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-surface to-transparent z-10"
        >
        </div>
        <div class="animate-marquee flex items-center gap-12">
          {
            [...clientLogos, ...clientLogos].map((client, i) => (
              <div class="flex-shrink-0 flex items-center justify-center px-6 py-4">
                <img
                  src={client.src}
                  alt={client.name}
                  class="max-h-12 w-auto object-contain"
                  loading="lazy"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="signal-section bg-surface-alt dot-grid">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div
        class="relative bg-surface rounded-2xl border border-neutral-300 p-10 lg:p-16 text-center overflow-hidden shadow-soft"
      >
        <!-- Background Accent -->
        <div
          class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-accent/10 rounded-full blur-[100px]"
        >
        </div>

        <!-- Constellation motif (bottom-left) -->
        <svg
          class="absolute bottom-0 left-0 pointer-events-none select-none opacity-60"
          width="220"
          height="180"
          viewBox="0 0 220 180"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <line
            x1="50"
            y1="140"
            x2="130"
            y2="90"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0s"></line>
          <line
            x1="50"
            y1="140"
            x2="20"
            y2="70"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0.1s"></line>
          <line
            x1="130"
            y1="90"
            x2="200"
            y2="110"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0.2s"></line>
          <line
            x1="130"
            y1="90"
            x2="150"
            y2="30"
            stroke="#C8A882"
            stroke-width="0.75"
            opacity="0.5"
            class="constellation-line"
            style="animation-delay: 0.3s"></line>
          <line
            x1="20"
            y1="70"
            x2="130"
            y2="90"
            stroke="#C8A882"
            stroke-width="0.5"
            opacity="0.2"
            class="constellation-line"
            style="animation-delay: 0.4s"></line>
          <line
            x1="150"
            y1="30"
            x2="200"
            y2="110"
            stroke="#C8A882"
            stroke-width="0.5"
            opacity="0.2"
            class="constellation-line"
            style="animation-delay: 0.45s"></line>
          <circle
            cx="130"
            cy="90"
            r="3.5"
            fill="#C8A882"
            opacity="0.6"
            class="constellation-node"
            style="--node-opacity: 0.6;  animation-delay: 0.1s"></circle>
          <circle
            cx="50"
            cy="140"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.45s"></circle>
          <circle
            cx="20"
            cy="70"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.5s"></circle>
          <circle
            cx="200"
            cy="110"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.55s"></circle>
          <circle
            cx="150"
            cy="30"
            r="2.2"
            fill="#C8A882"
            opacity="0.45"
            class="constellation-node"
            style="--node-opacity: 0.45; animation-delay: 0.6s"></circle>
        </svg>

        <div class="relative">
          <h2 class="text-3xl lg:text-4xl xl:text-5xl tracking-tight">
            <span class="font-display italic text-primary">Laten we praten over</span>
            <span class="font-sans font-semibold text-primary-light"> jouw groei</span>
          </h2>
          <p class="font-sans text-neutral-500 mt-4 max-w-xl mx-auto leading-relaxed">
            Klaar om je online zichtbaarheid te versterken? Ik help je graag met een strategie die
            past bij jouw ambitie.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <Button href={url('/contact/')} variant="primary" size="lg"> Contact opnemen </Button>
            <Button href={url('/services/')} variant="outline" size="lg"> Bekijk diensten </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BentoGrid from '../components/BentoGrid.astro';
import Button from '../components/Button.astro';
import { getCollection } from 'astro:content';
import { url } from '../lib/urls';

// Get services from content collection
const services = await getCollection('services');
const sortedServices = services.sort((a, b) => a.data.order - b.data.order);

// Client logos placeholder
const clientLogos = [
  { name: 'Client 1', initials: 'C1' },
  { name: 'Client 2', initials: 'C2' },
  { name: 'Client 3', initials: 'C3' },
  { name: 'Client 4', initials: 'C4' },
  { name: 'Client 5', initials: 'C5' },
];
---

<BaseLayout title="Iwan Stepanova — SEO Expert">
  <!-- Hero Section -->
  <Hero 
    title="De Strategische Architect voor Zoekmachine Dominantie"
    subtitle="Technical SEO, Content Architectuur & GEO voor de merken van morgen. Ik help ondernemingen groeien door strategische zoekmachine zichtbaarheid."
    ctaText="Start je Project"
    ctaHref={url('/contact')}
  />

  <!-- Services Bento Grid -->
  <section class="border-b-2 border-cyan">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24">
      <div class="text-center mb-12 lg:mb-16">
        <span class="font-mono text-sm text-cyan uppercase tracking-wider">
          Diensten
        </span>
        <h2 class="font-space font-bold text-3xl lg:text-4xl xl:text-5xl text-offwhite mt-4">
          Jouw groei, <span class="text-cyan">mijn expertise</span>
        </h2>
        <p class="font-inter text-slategray mt-4 max-w-2xl mx-auto">
          Complete SEO-oplossingen van strategie tot uitvoering. 
          Kies de dienst die bij jouw uitdaging past.
        </p>
      </div>

      <BentoGrid columns={3} gap="md">
        {sortedServices.map((service, index) => (
          <ServiceCard 
            title={service.data.title}
            description={service.data.description}
            icon={service.data.icon}
            href={url(`/services/${service.slug}`)}
            featured={service.data.featured}
          />
        ))}
      </BentoGrid>
    </div>
  </section>

  <!-- Client Logo Wall -->
  <section class="border-b-2 border-cyan bg-surface">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
      <div class="text-center mb-8">
        <span class="font-mono text-sm text-cyan uppercase tracking-wider">
          Vertrouwd door
        </span>
        <h2 class="font-space font-bold text-xl lg:text-2xl text-offwhite mt-2">
          Ondernemingen die groeien
        </h2>
      </div>

      <!-- Logo Grid (placeholder) -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 items-center">
        {clientLogos.map((client) => (
          <div class="flex items-center justify-center p-4 opacity-50 hover:opacity-100 transition-opacity duration-300">
            <div class="flex items-center gap-2">
              <div class="w-10 h-10 brutal-border flex items-center justify-center">
                <span class="font-mono text-sm text-cyan">{client.initials}</span>
              </div>
              <span class="font-inter text-sm text-slategray hidden md:block">{client.name}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-surface brutal-border p-8 lg:p-16 text-center">
        <h2 class="font-space font-bold text-3xl lg:text-4xl xl:text-5xl text-offwhite">
          Laten we praten over <span class="text-cyan">jouw groei</span>
        </h2>
        <p class="font-inter text-slategray mt-4 max-w-xl mx-auto">
          Klaar om je online zichtbaarheid te versterken? 
          Ik help je graag met een strategie die past bij jouw ambitie.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
          <Button href={url('/contact')} variant="primary" size="lg">
            Contact opnemen
          </Button>
          <Button href={url('/services')} variant="outline" size="lg">
            Bekijk diensten
          </Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
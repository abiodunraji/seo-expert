---
import { url } from '../lib/urls';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { href: 'https://www.linkedin.com/in/iwan-stepanova-seo/', label: 'LinkedIn' },
];

const footerLinks = [
  { href: url('/'), label: 'Home' },
  { href: url('/services/'), label: 'Services' },
  { href: url('/over/'), label: 'Over Iwan' },
  { href: url('/contact/'), label: 'Contact' },
  { href: url('/sitemap.xml'), label: 'Sitemap' },
];
---

<footer class="bg-surface border-t border-white/5">
  <!-- Footer Content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href={url('/')} class="inline-block mb-6">
          <span class="font-space font-bold text-2xl text-offwhite">
            IWAN
          </span>
          <span class="font-space font-bold text-2xl text-cyan">
            STEPANOVA
          </span>
        </a>
        <p class="font-inter text-slategray max-w-md leading-relaxed">
          De strategische architect voor zoekmachine dominantie. 
          Technical SEO, Content Architectuur & GEO voor de merken van morgen.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-cyan/70 mb-6">
          Navigatie
        </h3>
        <ul class="space-y-3">
          {footerLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class="font-inter text-slategray hover:text-cyan transition-colors duration-300 text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-mono text-xs uppercase tracking-[0.2em] text-cyan/70 mb-6">
          Connect
        </h3>
        <ul class="space-y-3">
          {socialLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                target="_blank"
                rel="noopener noreferrer"
                class="font-inter text-slategray hover:text-cyan transition-colors duration-300 text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="border-t border-white/5 mt-12 pt-8 flex flex-col lg:flex-row justify-between items-center gap-4">
      <p class="font-inter text-sm text-slategray/50">
        © {currentYear} Iwan Stepanova. All rights reserved.
      </p>
    </div>
  </div>
</footer>
---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/cases', label: 'Cases' },
  { href: '/over', label: 'Over' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-oxford border-b-2 border-cyan">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group">
        <span class="font-space font-bold text-xl lg:text-2xl text-offwhite group-hover:text-cyan transition-colors duration-300">
          IWAN
        </span>
        <span class="font-space font-bold text-xl lg:text-2xl text-cyan">
          STEPANOVA
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'font-mono text-sm uppercase tracking-wider transition-colors duration-300 relative',
              currentPath === item.href 
                ? 'text-cyan' 
                : 'text-offwhite hover:text-cyan'
            ]}
          >
            {item.label}
            {currentPath === item.href && (
              <span class="absolute -bottom-1 left-0 w-full h-0.5 bg-cyan"></span>
            )}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="lg:hidden p-2 text-offwhite hover:text-cyan transition-colors duration-300"
        aria-label="Toggle menu"
        id="mobile-menu-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden">
      <div class="px-4 py-4 space-y-4 border-t-2 border-cyan">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'block font-space text-2xl font-bold py-2 transition-colors duration-300',
              currentPath === item.href 
                ? 'text-cyan' 
                : 'text-offwhite hover:text-cyan'
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
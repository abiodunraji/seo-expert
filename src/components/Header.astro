---
import { url } from '../lib/urls';

const navItems = [
  { path: '/', label: 'Home' },
  { path: '/services/', label: 'Services' },
  { path: '/over/', label: 'Over' },
  { path: '/contact/', label: 'Contact' },
];

// Normalize the current path: remove trailing slash and base path
const rawPath = Astro.url.pathname;
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = rawPath.startsWith(basePath)
  ? rawPath.slice(basePath.length).replace(/\/$/, '')
  : rawPath.replace(/\/$/, '');

function isActive(path: string): boolean {
  const normalizedPath = path.replace(/\/$/, '') || '/';
  if (normalizedPath === '/') {
    return currentPath === '' || currentPath === '/';
  }
  return currentPath === normalizedPath || currentPath.startsWith(normalizedPath + '/');
}
---

<header class="sticky top-0 z-50 bg-surface/80 backdrop-blur-xl header-signal">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main navigation">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a href={url('/')} class="flex items-center gap-1.5 group">
        <span
          class="font-display italic text-xl lg:text-2xl text-primary group-hover:text-primary-light transition-colors duration-300"
        >
          Iwan
        </span>
        <span class="font-sans font-bold text-xl lg:text-2xl text-primary-light tracking-tight">
          Stepanova
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {
          navItems.map((item) => (
            <a
              href={url(item.path)}
              class:list={[
                'nav-signal font-sans text-sm font-medium transition-colors duration-300 px-4 py-2 rounded-lg',
                isActive(item.path)
                  ? 'text-primary bg-accent/10'
                  : 'text-neutral-500 hover:text-primary hover:bg-neutral-100/70',
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </div>

      <!-- Mobile Menu Button -->
      <button
        type="button"
        class="lg:hidden p-2 text-primary hover:text-primary-light transition-colors duration-300"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="mobile-menu-btn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden">
      <div class="px-4 py-4 space-y-2 border-t border-neutral-300">
        {
          navItems.map((item) => (
            <a
              href={url(item.path)}
              class:list={[
                'block font-sans text-lg font-medium py-3 px-4 rounded-lg transition-colors duration-300',
                isActive(item.path)
                  ? 'text-primary bg-primary/10'
                  : 'text-neutral-500 hover:text-primary hover:bg-neutral-100',
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn') as HTMLButtonElement | null;
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    const isOpen = !mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>

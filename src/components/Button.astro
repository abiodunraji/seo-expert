---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  label?: string;
}

const { 
  href, 
  variant = 'primary', 
  size = 'md',
  label
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-mono text-sm uppercase tracking-wider transition-all duration-300 rounded-full';

const variantClasses = {
  primary: 'bg-cyan text-oxford hover:bg-offwhite',
  secondary: 'bg-surface text-offwhite border border-white/10 hover:border-cyan/30',
  outline: 'bg-transparent text-cyan border border-cyan/30 hover:bg-cyan/10 hover:border-cyan',
};

const sizeClasses = {
  sm: 'px-5 py-2.5 text-xs',
  md: 'px-7 py-3 text-sm',
  lg: 'px-9 py-4 text-sm',
};
---

<a 
  href={href}
  class:list={[baseClasses, variantClasses[variant], sizeClasses[size]]}
>
  <slot />
  {label && <span class="ml-2">{label}</span>}
</a>
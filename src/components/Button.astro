---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  label?: string;
}

const { 
  href, 
  variant = 'primary', 
  size = 'md',
  label
} = Astro.props;

const baseClasses = 'inline-flex items-center justify-center font-sans font-medium text-sm transition-all duration-300 rounded-lg';

const variantClasses = {
  primary: 'bg-primary text-white hover:bg-primary-light hover:shadow-medium btn-amber-glow',
  secondary: 'bg-surface text-primary border border-neutral-300 hover:border-primary/30',
  outline: 'bg-transparent text-primary border border-primary/30 hover:bg-primary/5 hover:border-primary',
};

const sizeClasses = {
  sm: 'px-5 py-2.5 text-xs',
  md: 'px-7 py-3 text-sm',
  lg: 'px-9 py-4 text-sm',
};
---

<a 
  href={href}
  class:list={[baseClasses, variantClasses[variant], sizeClasses[size]]}
>
  <slot />
  {label && <span class="ml-2">{label}</span>}
</a>
---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  featured?: boolean;
}

const { title, description, icon, href = '#', featured = false } = Astro.props;

// Map of icons - in production use Lucide React components
const iconMap: Record<string, string> = {
  target: '🎯',
  chart: '📊',
  content: '✍️',
  code: '💻',
  link: '🔗',
  map: '📍',
  brain: '🧠',
};

const displayIcon = icon ? iconMap[icon] ?? '⚡' : '⚡';
---

<a 
  href={href}
  class:list={[
    'group block p-6 lg:p-8 brutal-border transition-all duration-300',
    featured 
      ? 'bg-cyan hover:bg-offwhite' 
      : 'bg-surface hover:bg-cyan/10'
  ]}
>
  <div class="flex items-start justify-between mb-4">
    <span class:list={[
      'text-3xl lg:text-4xl',
      featured ? 'text-oxford' : 'text-cyan'
    ]}>
      {displayIcon}
    </span>
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      class:list={[
        'w-5 h-5 transition-transform duration-300',
        featured ? 'text-oxford group-hover:translate-x-1 group-hover:-translate-y-1' : 'text-cyan group-hover:translate-x-1 group-hover:-translate-y-1'
      ]}
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
  
  <h3 class:list={[
    'font-space font-bold text-xl lg:text-2xl mb-3',
    featured ? 'text-oxford' : 'text-offwhite'
  ]}>
    {title}
  </h3>
  
  <p class:list={[
    'font-inter text-sm lg:text-base',
    featured ? 'text-oxford/80' : 'text-slategray'
  ]}>
    {description}
  </p>
</a>
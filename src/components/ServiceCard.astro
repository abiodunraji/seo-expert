---
import { getIcon } from '../lib/icons';

interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  featured?: boolean;
}

const { title, description, icon, href = '#', featured = false } = Astro.props;

const displayIcon = getIcon(icon);
---

{
  featured ? (
    <a
      href={href}
      class="group flex flex-col lg:flex-row lg:items-center gap-6 lg:gap-10 p-6 lg:p-10 rounded-xl border bg-accent/10 border-accent/30 card-hover card-signal card-signal-active transition-all duration-300 h-full"
    >
      <div
        class="flex-shrink-0 flex items-center justify-center w-14 h-14 rounded-xl bg-accent/20 text-primary"
        set:html={displayIcon}
      />

      <div class="flex-1 min-w-0">
        <h3 class="font-sans font-semibold text-xl text-primary mb-2">{title}</h3>
        <p class="font-sans text-sm text-neutral-500 leading-relaxed">{description}</p>
      </div>

      <div class="flex-shrink-0 flex items-center gap-2 text-primary-light group-hover:text-primary transition-colors duration-300">
        <span class="font-sans text-sm font-medium whitespace-nowrap">Meer info</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </a>
  ) : (
    <a
      href={href}
      class="group flex flex-col p-6 lg:p-8 rounded-xl border bg-surface border-neutral-300 hover:border-accent/20 transition-all duration-300 h-full card-hover card-signal"
    >
      <div
        class="flex items-center justify-center w-12 h-12 rounded-lg mb-6 bg-neutral-100 text-primary"
        set:html={displayIcon}
      />

      <h3 class="font-sans font-semibold text-xl text-primary mb-3">{title}</h3>

      <p class="font-sans text-sm text-neutral-500 flex-grow leading-relaxed">{description}</p>

      <div class="mt-6 pt-4 border-t border-neutral-300">
        <span class="font-sans text-sm text-primary-light group-hover:text-primary transition-colors duration-300">
          Meer info
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="inline-block w-4 h-4 ml-1 transition-transform duration-300 group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      </div>
    </a>
  )
}

---
interface Props {
  formId?: string;
}

const { formId = 'contact-form' } = Astro.props;
---

<form id={formId} class="space-y-5" novalidate>
  <!-- Honeypot field for spam protection -->
  <div class="hidden" aria-hidden="true">
    <label for="website">
      Do not fill this out
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <!-- CSRF Token -->
  <input type="hidden" id="csrf-token" name="csrf_token" value="" />

  <!-- Name -->
  <div>
    <label for="name" class="font-sans text-sm text-neutral-500 block mb-2">
      Naam *
    </label>
    <input 
      type="text" 
      id="name" 
      name="name"
      class="w-full bg-surface-alt border border-neutral-300 rounded-lg px-4 py-3 font-sans text-primary placeholder-neutral-500/50 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/25 transition-all duration-300"
      placeholder="Jouw naam"
      required
      minlength="2"
      maxlength="100"
      autocomplete="name"
    />
    <p class="error-message font-sans text-xs text-red-500 mt-1.5 hidden"></p>
  </div>

  <!-- Email -->
  <div>
    <label for="email" class="font-sans text-sm text-neutral-500 block mb-2">
      Email *
    </label>
    <input 
      type="email" 
      id="email" 
      name="email"
      class="w-full bg-surface-alt border border-neutral-300 rounded-lg px-4 py-3 font-sans text-primary placeholder-neutral-500/50 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/25 transition-all duration-300"
      placeholder="jouw@email.nl"
      required
      maxlength="254"
      autocomplete="email"
    />
    <p class="error-message font-sans text-xs text-red-500 mt-1.5 hidden"></p>
  </div>

  <!-- Company -->
  <div>
    <label for="company" class="font-sans text-sm text-neutral-500 block mb-2">
      Bedrijf
    </label>
    <input 
      type="text" 
      id="company" 
      name="company"
      class="w-full bg-surface-alt border border-neutral-300 rounded-lg px-4 py-3 font-sans text-primary placeholder-neutral-500/50 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/25 transition-all duration-300"
      placeholder="Jouw bedrijf"
      maxlength="100"
      autocomplete="organization"
    />
    <p class="error-message font-sans text-xs text-red-500 mt-1.5 hidden"></p>
  </div>

  <!-- Message -->
  <div>
    <label for="message" class="font-sans text-sm text-neutral-500 block mb-2">
      Bericht *
    </label>
    <textarea 
      id="message" 
      name="message"
      rows="4"
      class="w-full bg-surface-alt border border-neutral-300 rounded-lg px-4 py-3 font-sans text-primary placeholder-neutral-500/50 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/25 transition-all duration-300 resize-none"
      placeholder="Vertel me over jouw uitdaging..."
      required
      minlength="10"
      maxlength="2000"
    ></textarea>
    <p class="error-message font-sans text-xs text-red-500 mt-1.5 hidden"></p>
  </div>

  <!-- Submit Button -->
  <button 
    type="submit"
    id="submit-btn"
    class="w-full bg-primary text-white font-sans font-medium text-sm py-4 rounded-lg transition-all duration-300 hover:bg-primary-light hover:shadow-medium disabled:opacity-50 disabled:cursor-not-allowed btn-amber-glow"
  >
    <span class="btn-text">Verzenden</span>
    <span class="btn-loading hidden">Verzenden...</span>
  </button>

  <!-- Status Messages -->
  <div id="form-success" class="hidden bg-green-50 border border-green-200 rounded-lg px-4 py-3">
    <p class="font-sans text-sm text-green-700">
      Bedankt voor je bericht! Ik neem zo snel mogelijk contact met je op.
    </p>
  </div>

  <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-lg px-4 py-3">
    <p class="font-sans text-sm text-red-700" id="form-error-message">
      Er is iets misgegaan. Probeer het opnieuw.
    </p>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = submitBtn.querySelector('.btn-text') as HTMLElement;
  const btnLoading = submitBtn.querySelector('.btn-loading') as HTMLElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;
  const errorMessage = document.getElementById('form-error-message') as HTMLElement;
  const csrfToken = document.getElementById('csrf-token') as HTMLInputElement;

  // Generate CSRF token
  function generateToken(): string {
    const array = new Uint8Array(32);
    crypto.getRandomValues(array);
    return Array.from(array, b => b.toString(16).padStart(2, '0')).join('');
  }

  // Sanitize input
  function sanitize(input: string): string {
    const div = document.createElement('div');
    div.textContent = input;
    return div.innerHTML.trim();
  }

  // Validate email
  function isValidEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  // Show field error
  function showFieldError(field: HTMLElement, message: string): void {
    const errorEl = field.parentElement?.querySelector('.error-message');
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
    }
    field.classList.add('border-red-500');
  }

  // Clear field error
  function clearFieldError(field: HTMLElement): void {
    const errorEl = field.parentElement?.querySelector('.error-message');
    if (errorEl) {
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
    }
    field.classList.remove('border-red-500');
  }

  // Validate form
  function validateForm(): boolean {
    let isValid = true;
    const name = document.getElementById('name') as HTMLInputElement;
    const email = document.getElementById('email') as HTMLInputElement;
    const message = document.getElementById('message') as HTMLTextAreaElement;

    // Clear previous errors
    [name, email, message].forEach(clearFieldError);

    // Name validation
    if (!name.value.trim() || name.value.trim().length < 2) {
      showFieldError(name, 'Naam is verplicht (minimaal 2 tekens)');
      isValid = false;
    }

    // Email validation
    if (!email.value.trim() || !isValidEmail(email.value.trim())) {
      showFieldError(email, 'Voer een geldig e-mailadres in');
      isValid = false;
    }

    // Message validation
    if (!message.value.trim() || message.value.trim().length < 10) {
      showFieldError(message, 'Bericht is verplicht (minimaal 10 tekens)');
      isValid = false;
    }

    return isValid;
  }

  // Set CSRF token on load
  csrfToken.value = generateToken();

  // Handle form submission
  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    // Hide previous messages
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    // Validate
    if (!validateForm()) {
      return;
    }

    // Check honeypot
    const honeypot = (document.getElementById('website') as HTMLInputElement).value;
    if (honeypot) {
      return; // Silent fail for bots
    }

    // Set loading state
    submitBtn.disabled = true;
    btnText.classList.add('hidden');
    btnLoading.classList.remove('hidden');

    try {
      const formData = {
        name: sanitize((document.getElementById('name') as HTMLInputElement).value),
        email: sanitize((document.getElementById('email') as HTMLInputElement).value),
        company: sanitize((document.getElementById('company') as HTMLInputElement).value),
        message: sanitize((document.getElementById('message') as HTMLTextAreaElement).value),
        csrf_token: csrfToken.value,
        timestamp: Date.now(),
      };

      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        successMsg.classList.remove('hidden');
        form.reset();
        csrfToken.value = generateToken();
      } else {
        throw new Error(result.message || 'Er is iets misgegaan');
      }
    } catch (error) {
      errorMsg.classList.remove('hidden');
      errorMessage.textContent = error instanceof Error ? error.message : 'Er is iets misgegaan. Probeer het opnieuw.';
    } finally {
      submitBtn.disabled = false;
      btnText.classList.remove('hidden');
      btnLoading.classList.add('hidden');
    }
  });

  // Clear errors on input
  ['name', 'email', 'company', 'message'].forEach(id => {
    const el = document.getElementById(id);
    el?.addEventListener('input', () => clearFieldError(el as HTMLElement));
  });
</script>

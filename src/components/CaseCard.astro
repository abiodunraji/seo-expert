---
interface Props {
  client: string;
  title: string;
  summary: string;
  results?: { metric: string; value: string }[];
  href?: string;
}

const { client, title, summary, results = [], href = '#' } = Astro.props;
---

<a 
  href={href}
  class="group block bg-surface brutal-border p-6 lg:p-8 hover:bg-cyan/10 transition-all duration-300"
>
  <!-- Client Name -->
  <span class="font-mono text-sm text-cyan uppercase tracking-wider mb-2 block">
    {client}
  </span>
  
  <!-- Title -->
  <h3 class="font-space font-bold text-xl lg:text-2xl text-offwhite mb-4 group-hover:text-cyan transition-colors duration-300">
    {title}
  </h3>
  
  <!-- Summary -->
  <p class="font-inter text-slategray text-sm lg:text-base mb-6">
    {summary}
  </p>
  
  <!-- Results -->
  {results.length > 0 && (
    <div class="flex flex-wrap gap-4">
      {results.map((result) => (
        <div class="bg-oxford px-4 py-2 brutal-border-thin">
          <span class="font-mono text-xs text-cyan uppercase tracking-wider">
            {result.metric}
          </span>
          <span class="font-space font-bold text-lg text-offwhite ml-2">
            {result.value}
          </span>
        </div>
      ))}
    </div>
  )}
  
  <!-- Arrow -->
  <div class="mt-6 flex items-center text-cyan">
    <span class="font-mono text-sm uppercase tracking-wider mr-2">
      Bekijk case
    </span>
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1"
      fill="none" 
      viewBox="0 0 24 24" 
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
  </div>
</a>
---
interface Props {
  columns?: 2 | 3 | 4;
  gap?: 'sm' | 'md' | 'lg';
  centerLastRow?: boolean;
}

const { columns = 3, gap = 'md', centerLastRow = false } = Astro.props;

const gridClasses = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};

const gapClasses = {
  sm: 'gap-4',
  md: 'gap-6',
  lg: 'gap-8',
};
---

<div
  class:list={['grid', gridClasses[columns], gapClasses[gap], centerLastRow && 'center-last-row']}
>
  <slot />
</div>

<style>
  .center-last-row > :last-child:nth-child(3n + 1) {
    grid-column: 2;
  }
  .center-last-row > :last-child:nth-child(3n + 2) {
    grid-column: 1 / span 2;
    justify-self: center;
    max-width: calc(50% - 0.75rem);
  }
  @media (min-width: 1024px) {
    .center-last-row > :last-child:nth-child(3n + 1) {
      grid-column: 2;
    }
    .center-last-row > :last-child:nth-child(3n + 2) {
      grid-column: auto;
      max-width: none;
    }
  }
</style>

---
import { url } from '../lib/urls';

interface Props {
  title: string;
  subtitle?: string;
  showImage?: boolean;
  imageAlt?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { 
  title, 
  subtitle, 
  showImage = true,
  imageAlt = 'Iwan Stepanova',
  ctaText = 'Start je Project',
  ctaHref = '/contact'
} = Astro.props;
---

<section class="relative overflow-hidden py-20 lg:py-32 bg-surface-alt">
  <!-- Background Gradient -->
  <div class="absolute inset-0 bg-gradient-radial from-accent/10 via-transparent to-transparent opacity-50"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-accent/5 rounded-full blur-[120px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Text Content -->
      <div class="space-y-6 lg:space-y-8">
        <h1 class="font-sans font-semibold text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.1] tracking-tight">
          <span class="block text-primary">{title.split(' ').slice(0, 4).join(' ')}</span>
          <span class="block text-primary-light">{title.split(' ').slice(4).join(' ')}</span>
        </h1>
        
        {subtitle && (
          <p class="font-sans text-lg lg:text-xl text-neutral-500 max-w-xl leading-relaxed">
            {subtitle}
          </p>
        )}

        <div class="flex flex-wrap gap-4">
          <a 
            href={ctaHref}
            class="inline-flex items-center justify-center font-sans font-medium text-sm bg-primary text-white px-8 py-4 rounded-lg transition-all duration-300 hover:bg-primary-light hover:shadow-medium"
          >
            {ctaText}
            <svg 
              xmlns="http://www.w3.org/2000/svg" 
              class="w-4 h-4 ml-2"
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Image / Visual -->
      {showImage && (
        <div class="relative">
          <div class="absolute inset-0 bg-accent/5 rounded-2xl blur-3xl"></div>
          <div class="relative bg-surface rounded-2xl border border-neutral-300 overflow-hidden shadow-soft">
            <img 
              src={url('/images/iwan.png')} 
              alt={imageAlt} 
              class="w-full h-auto"
            />
          </div>
        </div>
      )}
    </div>
  </div>
</section>